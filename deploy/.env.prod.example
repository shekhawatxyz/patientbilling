# Copy to deploy/.env.prod and replace every placeholder before deployment.
# Never commit the populated .env.prod file.

SECRET_KEY=replace-with-a-long-random-secret
DATABASE_URL=postgresql://replace-user:replace-password@postgres:5432/replace-db
REDIS_URL=redis://redis:6379/0
ALLOWED_HOSTS=patientbilling.localhost
CSRF_TRUSTED_ORIGINS=https://patientbilling.example.com
FIELD_ENCRYPTION_KEY=replace-with-a-valid-field-encryption-key

# Required by the current Zango Compose services.
COMPOSE_PROJECT_NAME=patientbilling-prod
PROJECT_NAME=zango_project
POSTGRES_DB=patientbilling
POSTGRES_USER=replace-user
POSTGRES_PASSWORD=replace-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
REDIS_HOST=redis
REDIS_PORT=6379
PLATFORM_DOMAIN_URL=example.com
PLATFORM_USERNAME=replace-admin-email
PLATFORM_USER_PASSWORD=replace-admin-password
UPDATE_APPS_ON_STARTUP=false
