{
  "policies": [
    {
      "name": "AppViewPolicy",
      "description": "Serves the React SPA shell — accessible by all authenticated roles",
      "statement": {
        "permissions": [
          {"name": "backend.app.views.AppView", "type": "view"},
          {"name": "backend.app.views.RedirectAppView", "type": "view"},
          {"name": "backend.app.views.DashboardAPIView", "type": "view"}
        ]
      },
      "roles": ["AnonymousUsers", "BillingStaff", "BillingManager"]
    }
  ]
}
